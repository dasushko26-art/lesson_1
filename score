score = int(input("Введіть кількість балів за екзамен: "))

if 0 <= score <= 49:
    print("Незадовільно")
elif 50 <= score <= 69:
    print("Задовільно")
elif 70 <= score <= 89:
    print("Добре")
elif 90 <= score <= 100:
    print("Відмінно")
else:
    print("Помилка: бали мають бути від 0 до 100")
